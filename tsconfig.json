{
  "extends": "@modern-js/tsconfig/base.json",
  "compilerOptions": {
    "declaration": false,
    "jsx": "react-jsx",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "types": ["node", "tw5-typed"],
    "lib": ["DOM", "ESNext"]
  },
  "include": ["src", "eslint.config.mjs", "tailwind.config.js", "wiki/*.info", "src/**/*.d.ts", "wiki/tiddlers/tests/playwright/**/*.ts"]
}
